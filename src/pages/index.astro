---
import "../styles/global.css";
import SampleGrid from "../components/SampleGrid";

type MicroCMSSample = {
  id: string;
  title: string;
  description: string;
  thumbnail: { url: string };
  href: string;
};

type MicroCMSResponse = {
  contents: MicroCMSSample[];
};

const apiKey = import.meta.env.MICROCMS_API_KEY;
const baseUrl = import.meta.env.MICROCMS_BASE_URL;

const res = await fetch(`${baseUrl}/webglsamples`, {
  headers: { "X-MICROCMS-API-KEY": apiKey },
});

if (!res.ok) {
  throw new Error(`MicroCMS API error: ${res.status} ${res.statusText}`);
}

const data: MicroCMSResponse = await res.json();

const samples = data.contents.map((item) => ({
  title: item.title,
  description: item.description,
  thumbnail: item.thumbnail.url,
  href: item.href,
}));
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>WebGLサンプル集</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <h1 class="text-3xl font-bold mb-2">WebGLサンプル集</h1>
      <p class="text-muted-foreground mb-10">React Three Fiberを使ったインタラクティブな3Dデモ集です。</p>
      <SampleGrid samples={samples} />
    </div>
  </body>
</html>
