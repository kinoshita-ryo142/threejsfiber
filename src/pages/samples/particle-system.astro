---
import "../../styles/global.css";
import ParticleSystemScene from "../../components/three/ParticleSystem";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>パーティクルシステム | Three.js サンプル集</title>
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col">
    <header class="border-b px-6 py-4 flex items-center gap-4">
      <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
        ← サンプル一覧へ
      </a>
      <h1 class="text-lg font-semibold">パーティクルシステム</h1>
    </header>
    <main class="flex-1">
      <div class="w-full h-[calc(100vh-57px)]">
        <ParticleSystemScene client:only="react" />
      </div>
    </main>
  </body>
</html>
